    "110100": {
      "name": "风水涣",
      "guaxiang": "☴☵",
      "guaxiang_full": "⚊⚊⚋⚊⚋⚋",
      "neigua": "☵",
      "waigua": "☴",
      "gong": "离宫",
      "position": "游魂卦",
      "gua_ci": "亨，王假有庙，利涉大川。",
      "xiang_ci": "风行水上，涣。先王以享于帝。"
    },
    "111100": {
      "name": "天水讼",
      "guaxiang": "☰☵",
      "guaxiang_full": "⚊⚊⚊⚊⚋⚋",
      "neigua": "☵",
      "waigua": "☰",
      "gong": "离宫",
      "position": "归魂卦",
      "gua_ci": "有孚，窒惕，中吉终凶。",
      "xiang_ci": "天与水违行，讼。君子以作事谋始。"
    },
    "010010": {
      "name": "艮为山",
      "guaxiang": "☶☶",
      "guaxiang_full": "⚋⚊⚋⚋⚊⚋",
      "neigua": "☶",
      "waigua": "☶",
      "gong": "艮宫",
      "position": "本宫首卦",
      "gua_ci": "艮其背，不获其身，行其庭，不见其人，无咎。",
      "xiang_ci": "兼山，艮。君子以思不出其位。"
    },
    "010101": {
      "name": "山火贲",
      "guaxiang": "☶☲",
      "guaxiang_full": "⚋⚊⚋⚊⚋⚊",
      "neigua": "☲",
      "waigua": "☶",
      "gong": "艮宫",
      "position": "一世卦",
      "gua_ci": "亨，小利有攸往。",
      "xiang_ci": "山下有火，贲。君子以明庶政。"
    },
    "010111": {
      "name": "山天大畜",
      "guaxiang": "☶☰",
      "guaxiang_full": "⚋⚊⚋⚊⚊⚊",
      "neigua": "☰",
      "waigua": "☶",
      "gong": "艮宫",
      "position": "二世卦",
      "gua_ci": "利贞，不家食吉，利涉大川。",
      "xiang_ci": "天在山中，大畜。君子以多识前言往行，以畜其德。"
    },
    "010011": {
      "name": "山泽损",
      "guaxiang": "☶☱",
      "guaxiang_full": "⚋⚊⚋⚋⚊⚊",
      "neigua": "☱",
      "waigua": "☶",
      "gong": "艮宫",
      "position": "三世卦",
      "gua_ci": "有孚，元吉，无咎，可贞，利有攸往。",
      "xiang_ci": "山下有泽，损。君子以惩忿窒欲。"
    },
    "101011": {
      "name": "火泽睽",
      "guaxiang": "☲☱",
      "guaxiang_full": "⚊⚋⚊⚋⚊⚊",
      "neigua": "☱",
      "waigua": "☲",
      "gong": "艮宫",
      "position": "四世卦",
      "gua_ci": "小事吉。",
      "xiang_ci": "上火下泽，睽。君子以同而异。"
    },
    "111011": {
      "name": "天泽履",
      "guaxiang": "☰☱",
      "guaxiang_full": "⚊⚊⚊⚋⚊⚊",
      "neigua": "☱",
      "waigua": "☰",
      "gong": "艮宫",
      "position": "五世卦",
      "gua_ci": "履虎尾，不咥人，亨。",
      "xiang_ci": "上天下泽，履。君子以辨上下。"
    },
    "110011": {
      "name": "风泽中孚",
      "guaxiang": "☴☱",
      "guaxiang_full": "⚊⚊⚋⚋⚊⚊",
      "neigua": "☱",
      "waigua": "☴",
      "gong": "艮宫",
      "position": "游魂卦",
      "gua_ci": "豚鱼吉，利涉大川，利贞。",
      "xiang_ci": "泽上有风，中孚。君子以议狱缓死。"
    },
    "110010": {
      "name": "风山渐",
      "guaxiang": "☴☶",
      "guaxiang_full": "⚊⚊⚋⚋⚊⚋",
      "neigua": "☶",
      "waigua": "☴",
      "gong": "艮宫",
      "position": "归魂卦",
      "gua_ci": "女归吉，利贞。",
      "xiang_ci": "山上有木，渐。君子以居贤德。"
    },
    "011011": {
      "name": "兑为泽",
      "guaxiang": "☱☱",
      "guaxiang_full": "⚋⚊⚊⚋⚊⚊",
      "neigua": "☱",
      "waigua": "☱",
      "gong": "兑宫",
      "position": "本宫首卦",
      "gua_ci": "亨，利贞。",
      "xiang_ci": "丽泽，兑。君子以朋友讲习。"
    },
    "011100": {
      "name": "泽水困",
      "guaxiang": "☱☵",
      "guaxiang_full": "⚋⚊⚊⚊⚋⚋",
      "neigua": "☵",
      "waigua": "☱",
      "gong": "兑宫",
      "position": "一世卦",
      "gua_ci": "亨，贞，大人吉，无咎。",
      "xiang_ci": "泽无水，困。君子以致命遂志。"
    },
    "011000": {
      "name": "泽地萃",
      "guaxiang": "☱☷",
      "guaxiang_full": "⚋⚊⚊⚋⚋⚋",
      "neigua": "☷",
      "waigua": "☱",
      "gong": "兑宫",
      "position": "二世卦",
      "gua_ci": "亨，王假有庙，利见大人。",
      "xiang_ci": "泽上于地，萃。君子以除戎器。"
    },
    "011010": {
      "name": "泽山咸",
      "guaxiang": "☱☶",
      "guaxiang_full": "⚋⚊⚊⚋⚊⚋",
      "neigua": "☶",
      "waigua": "☱",
      "gong": "兑宫",
      "position": "三世卦",
      "gua_ci": "亨，利贞，取女吉。",
      "xiang_ci": "山上有泽，咸。君子以虚受人。"
    },
    "100010": {
      "name": "水山蹇",
      "guaxiang": "☵☶",
      "guaxiang_full": "⚊⚋⚋⚋⚊⚋",
      "neigua": "☶",
      "waigua": "☵",
      "gong": "兑宫",
      "position": "四世卦",
      "gua_ci": "利西南，不利东北，利见大人，贞吉。",
      "xiang_ci": "山上有水，蹇。君子以反身修德。"
    },
    "000010": {
      "name": "地山谦",
      "guaxiang": "☷☶",
      "guaxiang_full": "⚋⚋⚋⚋⚊⚋",
      "neigua": "☶",
      "waigua": "☷",
      "gong": "兑宫",
      "position": "五世卦",
      "gua_ci": "亨，君子有终。",
      "xiang_ci": "地中有山，谦。君子以裒多益寡。"
    },
    "001010": {
      "name": "雷山小过",
      "guaxiang": "☳☶",
      "guaxiang_full": "⚋⚋⚊⚋⚊⚋",
      "neigua": "☶",
      "waigua": "☳",
      "gong": "兑宫",
      "position": "游魂卦",
      "gua_ci": "亨，利贞，可小事，不可大事。",
      "xiang_ci": "山上有雷，小过。君子以行过乎恭。"
    },
    "001011": {
      "name": "雷泽归妹",
      "guaxiang": "☳☱",
      "guaxiang_full": "⚋⚋⚊⚋⚊⚊",
      "neigua": "☱",
      "waigua": "☳",
      "gong": "兑宫",
      "position": "归魂卦",
      "gua_ci": "征凶，无攸利。",
      "xiang_ci": "泽上有雷，归妹。君子以永终知敝。"
    }
